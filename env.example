import React, { useState, useEffect } from 'react';
import { motion, AnimatePresence } from 'framer-motion';
import { Cpu, Plus, X, CheckCircle, AlertTriangle, ShoppingCart, Share2, Save } from 'lucide-react';
import { productApi, buildApi } from '../utils/api';
import { useCart } from '../context/CartContext';
import { useAuth } from '../context/AuthContext';
import toast from 'react-hot-toast';

const slots = [
  { key: 'cpu', label: 'Processor', category: 'CPU', icon: '🔲' },
  { key: 'motherboard', label: 'Motherboard', category: 'Motherboard', icon: '🟩' },
  { key: 'gpu', label: 'Graphics Card', category: 'GPU', icon: '🎮' },
  { key: 'ram', label: 'Memory', category: 'RAM', icon: '💾', multi: true },
  { key: 'storage', label: 'Storage', category: 'Storage', icon: '💿', multi: true },
  { key: 'psu', label: 'Power Supply', category: 'PSU', icon: '⚡' },
  { key: 'cooling', label: 'CPU Cooler', category: 'Cooling', icon: '❄️' },
  { key: 'case', label: 'Cabinet', category: 'Case', icon: '📦' },
];

const Builder = () => {
  const [build, setBuild] = useState({ cpu: null, motherboard: null, gpu: null, ram: [], storage: [], psu: null, cooling: null, case: null });
  const [activeSlot, setActiveSlot] = useState(null);
  const [products, setProducts] = useState([]);
  const [search, setSearch] = useState('');
  const [compatibility, setCompatibility] = useState({ score: 100, issues: [] });
  const [buildName, setBuildName] = useState('My Custom Build');
  const [saving, setSaving] = useState(false);
  const { addToCart } = useCart();
  const { user } = useAuth();

  const totalPrice = Object.entries(build).reduce((sum, [key, val]) => {
    if (!val) return sum;
    if (Array.isArray(val)) return sum + val.reduce((s, p) => s + (p?.price || 0), 0);
    return sum + (val.price || 0);
  }, 0);

  const componentCount = Object.entries(build).reduce((sum, [key, val]) => {
    if (!val) return sum;
    if (Array.isArray(val)) return sum + val.length;
    return sum + 1;
  }, 0);

  useEffect(() => {
    if (!activeSlot) return;
    const slot = slots.find(s => s.key === activeSlot);
    const fetchProds = async () => {
      try {
        const { data } = await productApi.getAll({ category: slot.category, limit: 20, search });
        setProducts(data.products);
      } catch { toast.error('Failed to load products'); }
    };
    fetchProds();
  }, [activeSlot, search]);

  useEffect(() => {
    const checkCompat = async () => {
      const components = {};
      Object.entries(build).forEach(([k, v]) => { if (v) components[k] = Array.isArray(v) ? v.map(p => p._id) : v._id; });
      if (Object.keys(components).length === 0) return;
      try {
        const { data } = await buildApi.checkCompatibility({ components });
        setCompatibility(data);
      } catch {}
    };
    checkCompat();
  }, [build]);

  const selectComponent = (product) => {
    const slot = slots.find(s => s.key === activeSlot);
    setBuild(prev => {
      if (slot.multi) {
        const arr = prev[activeSlot] || [];
        return { ...prev, [activeSlot]: [...arr, product] };
      }
      return { ...prev, [activeSlot]: product };
    });
    setActiveSlot(null);
    setSearch('');
    toast.success(`${product.name} added!`);
  };

  const removeComponent = (key, idx = null) => {
    setBuild(prev => {
      if (idx !== null) return { ...prev, [key]: prev[key].filter((_, i) => i !== idx) };
      return { ...prev, [key]: null };
    });
  };

  const saveBuild = async () => {
    if (!user) { toast.error('Please login to save builds'); return; }
    setSaving(true);
    try {
      const components = {};
      Object.entries(build).forEach(([k, v]) => { if (v) components[k] = Array.isArray(v) ? v.map(p => p._id) : v._id; });
      const { data } = await buildApi.create({ components, name: buildName, isPublic: false });
      toast.success('Build saved!');
    } catch (err) { toast.error('Failed to save build');
    } finally { setSaving(false); }
  };

  const addAllToCart = () => {
    Object.entries(build).forEach(([key, val]) => {
      if (!val) return;
      if (Array.isArray(val)) val.forEach(p => p && addToCart(p));
      else addToCart(val);
    });
    toast.success('All components added to cart!');
  };

  return (
    <div className="container" style={{ padding: '40px 24px' }}>
      <motion.div initial={{ opacity: 0, y: -20 }} animate={{ opacity: 1, y: 0 }} style={{ marginBottom: 32 }}>
        <span className="badge badge-green" style={{ marginBottom: 12, display: 'inline-block' }}>PC Builder</span>
        <h1 style={{ fontFamily: 'Orbitron', fontSize: 'clamp(1.5rem, 4vw, 2.5rem)', marginBottom: 8 }}>
          <span className="gradient-text">BUILD</span> YOUR PC
        </h1>
        <p style={{ color: '#64748b' }}>Select components below. Real-time compatibility checking included.</p>
      </motion.div>

      <div style={{ display: 'grid', gridTemplateColumns: '1fr 320px', gap: 32 }}>
        {/* Component Slots */}
        <div>
          {slots.map(slot => {
            const value = build[slot.key];
            const items = slot.multi ? (value || []) : (value ? [value] : []);
            return (
              <motion.div key={slot.key} initial={{ opacity: 0, x: -20 }} animate={{ opacity: 1, x: 0 }}
                className="glass" style={{ borderRadius: 12, padding: '16px 20px', marginBottom: 12, border: '1px solid rgba(0,212,255,0.1)', transition: 'all 0.3s' }}>
                <div style={{ display: 'flex', alignItems: 'center', gap: 16 }}>
                  <span style={{ fontSize: '1.5rem' }}>{slot.icon}</span>
                  <div style={{ flex: 1 }}>
                    <div style={{ fontFamily: 'Orbitron', fontSize: '0.7rem', color: '#475569', letterSpacing: 1, marginBottom: 4 }}>{slot.label}</div>
                    {items.length === 0 ? (
                      <span style={{ color: '#334155', fontSize: '0.9rem' }}>No component selected</span>
                    ) : (
                      <div style={{ display: 'flex', flexDirection: 'column', gap: 6 }}>
                        {items.map((item, i) => (
                          <div key={i} style={{ display: 'flex', alignItems: 'center', gap: 8, justifyContent: 'space-between' }}>
                            <span style={{ color: '#e2e8f0', fontSize: '0.9rem' }}>{item.name}</span>
                            <div style={{ display: 'flex', alignItems: 'center', gap: 8 }}>
                              <span style={{ fontFamily: 'Orbitron', color: '#00d4ff', fontSize: '0.85rem' }}>₹{item.price?.toLocaleString()}</span>
                              <motion.button whileHover={{ scale: 1.2 }} onClick={() => removeComponent(slot.key, slot.multi ? i : null)}
                                style={{ background: 'none', border: 'none', color: '#ff2d7d', cursor: 'pointer', display: 'flex' }}><X size={14} /></motion.button>
                            </div>
                          </div>
                        ))}
                      </div>
                    )}
                  </div>
                  <motion.button whileHover={{ scale: 1.05 }} whileTap={{ scale: 0.95 }} onClick={() => setActiveSlot(slot.key)}
                    style={{ display: 'flex', alignItems: 'center', gap: 6, padding: '8px 16px', background: 'rgba(0,212,255,0.1)', border: '1px solid rgba(0,212,255,0.3)', color: '#00d4ff', cursor: 'pointer', borderRadius: 6, fontFamily: 'Orbitron', fontSize: '0.65rem', whiteSpace: 'nowrap' }}>
                    <Plus size={14} /> SELECT
                  </motion.button>
                </div>
              </motion.div>
            );
          })}
        </div>

        {/* Summary Panel */}
        <div style={{ position: 'sticky', top: 90, height: 'fit-content' }}>
          <div className="glass" style={{ borderRadius: 16, padding: 24, marginBottom: 16 }}>
            <h3 style={{ fontFamily: 'Orbitron', fontSize: '0.85rem', marginBottom: 16, color: '#00d4ff' }}>BUILD SUMMARY</h3>
            <input value={buildName} onChange={e => setBuildName(e.target.value)} className="input-cyber" style={{ width: '100%', marginBottom: 16, fontSize: '0.9rem' }} placeholder="Build name..." />

            {/* Compatibility */}
            <div style={{ padding: '12px 16px', borderRadius: 8, background: compatibility.score >= 80 ? 'rgba(0,255,136,0.08)' : 'rgba(255,165,0,0.08)', border: `1px solid ${compatibility.score >= 80 ? 'rgba(0,255,136,0.3)' : 'rgba(255,165,0,0.3)'}`, marginBottom: 16 }}>
              <div style={{ display: 'flex', alignItems: 'center', gap: 8, marginBottom: 6 }}>
                {compatibility.score >= 80 ? <CheckCircle size={16} color="#00ff88" /> : <AlertTriangle size={16} color="orange" />}
                <span style={{ fontFamily: 'Orbitron', fontSize: '0.7rem', color: compatibility.score >= 80 ? '#00ff88' : 'orange' }}>
                  COMPATIBILITY: {compatibility.score}%
                </span>
              </div>
              {compatibility.issues.map((issue, i) => (
                <p key={i} style={{ color: 'orange', fontSize: '0.78rem', marginTop: 4 }}>⚠ {issue}</p>
              ))}
            </div>

            <div style={{ display: 'flex', justifyContent: 'space-between', alignItems: 'center', marginBottom: 8 }}>
              <span style={{ color: '#64748b' }}>Components</span>
              <span style={{ color: '#e2e8f0' }}>{componentCount}/8</span>
            </div>
            <div className="divider-neon" />
            <div style={{ display: 'flex', justifyContent: 'space-between', alignItems: 'center', marginBottom: 20 }}>
              <span style={{ fontFamily: 'Orbitron', fontSize: '0.8rem', color: '#64748b' }}>TOTAL</span>
              <span style={{ fontFamily: 'Orbitron', fontSize: '1.4rem', color: '#00d4ff' }}>₹{totalPrice.toLocaleString()}</span>
            </div>

            <div style={{ display: 'flex', flexDirection: 'column', gap: 10 }}>
              <motion.button whileHover={{ scale: 1.02 }} whileTap={{ scale: 0.98 }} onClick={addAllToCart}
                disabled={componentCount === 0} className="btn-primary"
                style={{ width: '100%', display: 'flex', alignItems: 'center', justifyContent: 'center', gap: 8, opacity: componentCount === 0 ? 0.5 : 1 }}>
                <ShoppingCart size={16} /> ADD ALL TO CART
              </motion.button>
              <motion.button whileHover={{ scale: 1.02 }} onClick={saveBuild} disabled={saving || componentCount === 0}
                className="btn-neon" style={{ width: '100%', display: 'flex', alignItems: 'center', justifyContent: 'center', gap: 8, opacity: componentCount === 0 ? 0.5 : 1 }}>
                <Save size={16} /> {saving ? 'SAVING...' : 'SAVE BUILD'}
              </motion.button>
            </div>
          </div>
        </div>
      </div>

      {/* Product Selector Modal */}
      <AnimatePresence>
        {activeSlot && (
          <motion.div initial={{ opacity: 0 }} animate={{ opacity: 1 }} exit={{ opacity: 0 }}
            onClick={() => setActiveSlot(null)}
            style={{ position: 'fixed', inset: 0, background: 'rgba(0,0,0,0.8)', zIndex: 1000, display: 'flex', alignItems: 'center', justifyContent: 'center', padding: 24 }}>
            <motion.div initial={{ scale: 0.9, opacity: 0 }} animate={{ scale: 1, opacity: 1 }} exit={{ scale: 0.9, opacity: 0 }}
              onClick={e => e.stopPropagation()} className="glass"
              style={{ width: '100%', maxWidth: 700, maxHeight: '80vh', borderRadius: 16, overflow: 'hidden', display: 'flex', flexDirection: 'column' }}>
              <div style={{ padding: '20px 24px', borderBottom: '1px solid rgba(0,212,255,0.1)', display: 'flex', justifyContent: 'space-between', alignItems: 'center' }}>
                <h3 style={{ fontFamily: 'Orbitron', color: '#00d4ff' }}>
                  SELECT {slots.find(s => s.key === activeSlot)?.label.toUpperCase()}
                </h3>
                <motion.button whileHover={{ scale: 1.1 }} onClick={() => setActiveSlot(null)}
                  style={{ background: 'none', border: 'none', color: '#64748b', cursor: 'pointer', display: 'flex' }}><X size={20} /></motion.button>
              </div>
              <div style={{ padding: '16px 24px', borderBottom: '1px solid rgba(0,212,255,0.1)' }}>
                <input value={search} onChange={e => setSearch(e.target.value)} className="input-cyber" style={{ width: '100%' }} placeholder="Search..." />
              </div>
              <div style={{ overflowY: 'auto', padding: '16px 24px', flex: 1 }}>
                {products.map(product => (
                  <motion.div key={product._id} whileHover={{ backgroundColor: 'rgba(0,212,255,0.05)', x: 4 }}
                    onClick={() => selectComponent(product)}
                    style={{ display: 'flex', alignItems: 'center', gap: 16, padding: '14px 16px', cursor: 'pointer', borderRadius: 8, marginBottom: 8, border: '1px solid rgba(0,212,255,0.08)', transition: 'all 0.2s' }}>
                    <div style={{ width: 50, height: 50, background: 'rgba(0,212,255,0.05)', borderRadius: 6, display: 'flex', alignItems: 'center', justifyContent: 'center', flexShrink: 0 }}>
                      <Cpu size={24} color="rgba(0,212,255,0.4)" />
                    </div>
                    <div style={{ flex: 1 }}>
                      <div style={{ fontFamily: 'Orbitron', fontSize: '0.8rem', color: '#e2e8f0', marginBottom: 4 }}>{product.name}</div>
                      <div style={{ color: '#475569', fontSize: '0.8rem' }}>{product.brand}</div>
                    </div>
                    <div style={{ fontFamily: 'Orbitron', color: '#00d4ff', fontSize: '0.9rem', flexShrink: 0 }}>₹{product.price?.toLocaleString()}</div>
                  </motion.div>
                ))}
                {products.length === 0 && <div style={{ textAlign: 'center', color: '#334155', padding: '40px 0' }}>No products found</div>}
              </div>
            </motion.div>
          </motion.div>
        )}
      </AnimatePresence>

      <style>{`@media(max-width:900px){.container > div:nth-child(3){grid-template-columns:1fr !important;}}`}</style>
    </div>
  );
};

export default Builder;
